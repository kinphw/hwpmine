# ── MariaDB 연결 정보 ──────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=hwp_documents
DB_TABLE=documents

# ── 스캔 설정 ──────────────────────────────────────────────────
# 스캔할 드라이브 (쉼표 구분)
SCAN_DRIVES=C:\,D:\

# ── CSV 경로 ───────────────────────────────────────────────────
# HWP 스캐너 출력 / HWP 적재기 입력
CSV_FILE=hwp_file_list.csd

# PDF 스캐너 출력 / PDF 적재기 입력 (선택)
# 미지정 시 CSV_FILE 옆에 같은 폴더·확장자·패턴(hwp→pdf)으로 자동 배치
#   예) hwp_file_list.csd → pdf_file_list.csd
# PDF_CSV_FILE=pdf_file_list.csd

# ── 적재 성능 튜닝 (선택) ─────────────────────────────────────
COMMIT_EVERY=50
COM_RESTART=500
PARSE_TIMEOUT=60

# PDF 적재 워커 수 — 0 또는 미지정 시 os.cpu_count() 자동
# PDF_WORKERS=0
