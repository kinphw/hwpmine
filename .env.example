# ── MariaDB 연결 정보 ──────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=hwp_documents
DB_TABLE=documents

# ── 스캔 설정 ──────────────────────────────────────────────────
# 스캔할 드라이브 (쉼표 구분)
SCAN_DRIVES=C:\,D:\

# ── CSV 경로 ───────────────────────────────────────────────────
# scanner 출력 / inserter 입력으로 공유되는 파일
CSV_FILE=hwp_file_list.csd

# ── 적재 성능 튜닝 (선택) ─────────────────────────────────────
COMMIT_EVERY=50
COM_RESTART=500
PARSE_TIMEOUT=60
